# ─── Frontend (Vite public) ──────────────────────────────────────────────────
# Supabase project URL and anon key (safe to expose in the browser)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_ANON_KEY=

# Web Push (VAPID public key — shared with the browser to subscribe)
# Generate with: npx web-push generate-vapid-keys --json
# Set the private key + email as Supabase secrets (see below), NOT here.
VITE_VAPID_PUBLIC_KEY=

# ─── Supabase Edge Function secrets ──────────────────────────────────────────
# Set these via: supabase secrets set KEY=value
# or in the Supabase dashboard → Settings → Edge Functions → Secrets

# AI / LLM
GROQ_API_KEY=                    # Groq API key (ai-search, support functions)

# Payments — PayMongo (Philippine e-wallets + cards)
PAYMONGO_SECRET_KEY=             # sk_live_... or sk_test_...
PAYMONGO_WEBHOOK_SECRET=         # From PayMongo dashboard → Webhooks

# Payments — Stripe (optional, for card top-ups / memberships)
STRIPE_SECRET_KEY=               # sk_live_... or sk_test_...
STRIPE_WEBHOOK_SECRET=           # whsec_... from Stripe dashboard → Webhooks

# Transactional email (Resend — graceful no-op if absent)
RESEND_API_KEY=                  # re_...
RESEND_FROM_EMAIL=               # e.g. no-reply@cheapstays.me

# Partner hotel search (Agoda Affiliate API — graceful no-op if absent)
AGODA_SITE_ID=                   # Numeric site ID from affiliates.agoda.com
AGODA_API_KEY=                   # API key from the affiliate portal

# Web Push (server-side VAPID credentials)
VAPID_PRIVATE_KEY=               # Paired with VITE_VAPID_PUBLIC_KEY above
VAPID_EMAIL=                     # mailto:admin@cheapstays.me

# Deployment
SITE_URL=                        # e.g. https://cheapstays.me (for redirect URLs)

# ─── Auto-provided by Supabase (do not set manually) ─────────────────────────
# SUPABASE_URL
# SUPABASE_ANON_KEY
# SUPABASE_SERVICE_ROLE_KEY
# SUPABASE_DB_URL
